{
  "name": "crm-chat",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "cli": "CRM_CHAT_BASE_URL=http://localhost:7072 tsx cli/testChatCli.ts",
    "dev": "npm run build && concurrently -k -n tsc,func -c blue,green \"npm run watch\" \"func start --port 7072\"",
    "prestart": "npm run clean && npm run build",
    "start": "func start --port 7072"
  },
  "dependencies": {
    "@azure/functions": "^4.7.3",
    "llm-runtime": "^0.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "concurrently": "^9.2.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  },
  "main": "dist/index.js",
  "engines": {
    "node": ">=22 <23"
  }
}
